<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Quản lý Phòng Chiếu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/sodoghe.css">
</head>

<body class="bg-light">
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Quản lý Phòng Chiếu & Sơ Đồ Ghế</h2>
            <a href="/admin" class="btn btn-secondary">Về Dashboard</a>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-success text-white fw-bold">Thêm Phòng Chiếu Mới</div>
            <div class="card-body">
                <form id="formTaoPhong">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Tên Phòng</label>
                            <input type="text" id="tenPhong" class="form-control" placeholder="VD: Phòng Chiếu 03"
                                required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Số Hàng Ghế (A, B, C...)</label>
                            <input type="number" id="soHang" class="form-control" placeholder="VD: 10" required>
                            <small class="text-muted">Gợi ý: 10 hàng tương ứng từ A đến J</small>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Số Cột Ghế (1, 2, 3...)</label>
                            <input type="number" id="soCot" class="form-control" placeholder="VD: 12" required>
                            <small class="text-muted">Gợi ý: Mỗi hàng có 12 ghế</small>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success px-4">Lưu Phòng & Tự động tạo ghế</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm mb-5">
            <div class="card-header bg-dark text-white fw-bold">Danh sách Phòng đang hoạt động</div>
            <div class="card-body p-0">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center">Mã Phòng</th>
                            <th>Tên Phòng</th>
                            <th class="text-center">Tổng Số Ghế</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof phongs !=='undefined' && phongs.length> 0) { %>
                            <% phongs.forEach(p=> { %>
                                <tr>
                                    <td class="text-center fw-bold">
                                        <%= p.MA_PHONG_CHIEU %>
                                    </td>
                                    <td>
                                        <%= p.TEN_PHONG_CHIEU %>
                                    </td>
                                    <td class="text-center">
                                        <%= p.TONG_SO_GHE || 'Đang tính...' %> ghế
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-info text-white fw-bold btn-xem-sodo"
                                            data-id="<%= p.MA_PHONG_CHIEU %>" data-ten="<%= p.TEN_PHONG_CHIEU %>">
                                            Xem sơ đồ
                                        </button>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="text-center py-4">Chưa có phòng chiếu nào được tạo.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="sodoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title" id="modalTitle">Sơ đồ ghế</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body bg-light text-center py-4" style="overflow-x: auto;">
                    <div class="screen-cinema">MÀN HÌNH</div>

                    <div id="seatContainer">
                    </div>
                </div>
                <div class="modal-footer justify-content-center bg-white border-top-0">
                    <div class="d-flex gap-4">
                        <div class="d-flex align-items-center gap-2">
                            <span class="seat seat-thuong" style="width: 25px; height: 25px;"></span>
                            <span class="fw-bold">Ghế Thường</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="seat seat-vip" style="width: 25px; height: 25px;"></span>
                            <span class="fw-bold">Ghế VIP</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // 1. Xử lý Form Lưu Phòng Mới
        document.getElementById('formTaoPhong').addEventListener('submit', async (e) => {
            e.preventDefault();

            const data = {
                tenPhong: document.getElementById('tenPhong').value,
                soHang: document.getElementById('soHang').value,
                soCot: document.getElementById('soCot').value,
                maRap: 1 // Giả định mã rạp mặc định
            };

            try {
                const response = await fetch('/admin/phong/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (result.success) {
                    alert('Thành công: ' + result.message);
                    window.location.reload();
                } else {
                    alert('Lỗi: ' + result.message);
                }
            } catch (err) {
                console.error(err);
                alert('Lỗi kết nối đến server!');
            }
        });

        // 2. Xử lý nút "Xem sơ đồ"
        const modalSoDo = new bootstrap.Modal(document.getElementById('sodoModal'));
        const btnXemSoDo = document.querySelectorAll('.btn-xem-sodo');

        btnXemSoDo.forEach(btn => {
            btn.addEventListener('click', async function () {
                const maPhong = this.getAttribute('data-id');
                const tenPhong = this.getAttribute('data-ten');

                // Đổi tiêu đề Modal
                document.getElementById('modalTitle').innerText = `Sơ đồ - ${tenPhong}`;

                const container = document.getElementById('seatContainer');
                container.innerHTML = '<div class="spinner-border text-primary my-5" role="status"></div>';

                // Mở popup lên trước cho mượt
                modalSoDo.show();

                try {
                    // Gọi API lấy dữ liệu ghế
                    const response = await fetch(`/admin/phong/${maPhong}/ghe`);
                    const result = await response.json();

                    if (result.success) {
                        // Phân nhóm ghế theo chữ cái đầu (VD: Tất cả ghế A vào mảng 'A')
                        const seatMap = {};
                        result.data.forEach(ghe => {
                            const row = ghe.TEN_GHE_NGOI.charAt(0);
                            if (!seatMap[row]) seatMap[row] = [];
                            seatMap[row].push(ghe);
                        });

                        // Vẽ HTML sơ đồ
                        let html = '';
                        for (let row in seatMap) {
                            html += `<div class="seat-row">`;
                            // Cột hiển thị tên Hàng (A, B, C)
                            html += `<div style="width: 30px; line-height: 40px; font-weight: bold; text-align: right; margin-right: 15px;">${row}</div>`;

                            seatMap[row].forEach(ghe => {
                                // Nếu loại ghế là VIP (so sánh không phân biệt hoa/thường)
                                const seatClass = (ghe.TRANG_THAI_GHE.toLowerCase() === 'vip') ? 'seat-vip' : 'seat-thuong';
                                html += `<div class="seat ${seatClass}" title="Loại: ${ghe.TRANG_THAI_GHE}">${ghe.TEN_GHE_NGOI}</div>`;
                            });

                            // Cột hiển thị tên Hàng ở bên phải (Tuỳ chọn cho cân đối)
                            html += `<div style="width: 30px; line-height: 40px; font-weight: bold; text-align: left; margin-left: 15px;">${row}</div>`;
                            html += `</div>`;
                        }
                        container.innerHTML = html;
                    } else {
                        container.innerHTML = `<p class="text-danger fw-bold my-5">${result.message}</p>`;
                    }
                } catch (err) {
                    container.innerHTML = `<p class="text-danger fw-bold my-5">Lỗi kết nối máy chủ!</p>`;
                }
            });
        });
    </script>
</body>

</html>