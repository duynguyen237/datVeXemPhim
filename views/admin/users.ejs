<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('../partials/head') %>
        <title>Quản lý Khách Hàng - Admin</title>
</head>

<body class="bg-light">

    <div class="container py-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h4 class="mb-0 text-warning"><i class="bi bi-people-fill"></i> Danh Sách Người Dùng</h4>
                <a href="/admin" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại
                    Dashboard</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Họ Tên</th>
                                <th>Tên Đăng Nhập</th>
                                <th>Email</th>
                                <th>Số điện thoại</th>
                                <th>Vai Trò</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(user=> { %>
                                <tr>
                                    <td>
                                        <%= user.MA_NGUOI_DUNG %>
                                    </td>
                                    <td class="fw-bold">
                                        <%= user.HO_TEN %>
                                    </td>
                                    <td>
                                        <%= user.TEN_DANG_NHAP %>
                                    </td>
                                    <td>
                                        <%= user.EMAIL %>
                                    </td>
                                    <td>
                                        <%= user.SO_DIEN_THOAI %>
                                    </td>
                                    <td>
                                        <% if(user.MA_VAI_TRO===1) { %>
                                            <span class="badge bg-danger">
                                                <%= user.TEN_VAI_TRO %> (Admin)
                                            </span>
                                            <% } else { %>
                                                <span class="badge bg-primary">
                                                    <%= user.TEN_VAI_TRO %>
                                                </span>
                                                <% } %>
                                    </td>
                                    <td>
                                        <% if(user.MA_VAI_TRO !==1) { %>
                                            <button class="btn btn-sm btn-outline-danger"
                                                onclick="alert('Tính năng khóa/xóa tài khoản đang bảo trì!')">
                                                <i class="bi bi-lock"></i> Khóa
                                            </button>
                                            <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</body>

</html>