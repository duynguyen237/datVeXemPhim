<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('../partials/head') %>
        <title>Bảng Điều Khiển - Admin Duy Movie</title>
        <style>
            .admin-card {
                transition: transform 0.2s, box-shadow 0.2s;
                border-left: 5px solid #dc3545;
            }

            .admin-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
            }

            .admin-icon {
                font-size: 3rem;
                color: #dc3545;
            }
        </style>
</head>

<body class="bg-light text-dark">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-danger" href="/admin">
                <i class="bi bi-film"></i> DUY MOVIE ADMIN
            </a>
            <div class="d-flex align-items-center">
                <a href="/" class="btn btn-outline-light btn-sm me-3"><i class="bi bi-shop"></i> Xem trang khách
                    hàng</a>
                <span class="text-white me-3" id="admin-name">Chào, Admin</span>
                <button onclick="logout()" class="btn btn-sm btn-danger">Thoát</button>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row mb-4">
            <div class="col-12">
                <h2 class="fw-bold">Bảng Điều Khiển (Dashboard)</h2>
                <p class="text-muted">Quản lý toàn bộ hệ thống rạp chiếu phim của bạn tại đây.</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <a href="/admin/phim" class="text-decoration-none text-dark">
                    <div class="card shadow-sm border-0 admin-card h-100 p-3">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <div>
                                <h4 class="fw-bold mb-1">Quản lý Phim</h4>
                                <span class="text-muted">Thêm, sửa, xóa danh sách phim</span>
                            </div>
                            <i class="bi bi-camera-reels admin-icon"></i>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="/admin/suat-chieu" class="text-decoration-none text-dark">
                    <div class="card shadow-sm border-0 admin-card h-100 p-3" style="border-left-color: #0d6efd;">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <div>
                                <h4 class="fw-bold mb-1">Suất Chiếu & Rạp</h4>
                                <span class="text-muted">Xếp lịch chiếu, quản lý phòng</span>
                            </div>
                            <i class="bi bi-calendar-week admin-icon" style="color: #0d6efd;"></i>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 mb-4">
                <a href="/admin/phong" class="text-decoration-none text-dark">
                    <div class="card h-100 shadow-sm border-0 dashboard-card">
                        <div class="card-body d-flex justify-content-between align-items-center p-4">
                            <div>
                                <h5 class="fw-bold mb-1">Phòng & Ghế</h5>
                                <p class="text-muted mb-0" style="font-size: 0.9rem;">Thêm phòng chiếu, xem sơ đồ</p>
                            </div>
                            <div style="color: #0d6efd;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor"
                                    class="bi bi-ui-checks-grid" viewBox="0 0 16 16">
                                    <path
                                        d="M2 10h3a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1zm9-9h3a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zm0 9a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1h-3zm0-10a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h3a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2h-3zM2 9a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h3a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H2zm7 2a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-3a2 2 0 0 1-2-2v-3zM0 2a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm5.354.854a.5.5 0 1 0-.708-.708L3 3.793l-.646-.647a.5.5 0 1 0-.708.708l1 1a.5.5 0 0 0 .708 0l2-2z" />
                                </svg>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="/admin/doanh-thu" class="text-decoration-none text-dark">
                    <div class="card shadow-sm border-0 admin-card h-100 p-3" style="border-left-color: #198754;">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <div>
                                <h4 class="fw-bold mb-1">Doanh Thu</h4>
                                <span class="text-muted">Xem biểu đồ, báo cáo tài chính</span>
                            </div>
                            <i class="bi bi-graph-up-arrow admin-icon" style="color: #198754;"></i>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 mt-4">
                <a href="/admin/users" class="text-decoration-none text-dark">
                    <div class="card shadow-sm border-0 admin-card h-100 p-3" style="border-left-color: #ffc107;">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <div>
                                <h4 class="fw-bold mb-1">Khách Hàng</h4>
                                <span class="text-muted">Quản lý tài khoản người dùng</span>
                            </div>
                            <i class="bi bi-people admin-icon" style="color: #ffc107;"></i>
                        </div>
                    </div>
                </a>
            </div>
        </div>
        <div class="col-md-4 mt-4">
            <a href="/admin/hoa-don" class="text-decoration-none text-dark">
                <div class="card shadow-sm border-0 admin-card h-100 p-3" style="border-left-color: #6f42c1;">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <h4 class="fw-bold mb-1">Hóa Đơn</h4>
                            <span class="text-muted">Quản lý vé đã bán</span>
                        </div>
                        <i class="bi bi-receipt admin-icon" style="color: #6f42c1;"></i>
                    </div>
                </div>
            </a>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/main.js"></script>
    <script>
        // Bảo vệ trang Admin ngay lập tức
        const adminUser = JSON.parse(localStorage.getItem('user'));
        if (!adminUser || adminUser.MA_VAI_TRO !== 1) {
            document.body.innerHTML = '<h1 style="text-align:center; margin-top:50px; color:red;">⛔ BẠN KHÔNG CÓ QUYỀN TRUY CẬP!</h1>';
            setTimeout(() => { window.location.href = '/'; }, 1500);
        } else {
            document.getElementById('admin-name').innerText = `Chào, ${adminUser.HO_TEN}`;
        }
    </script>
</body>

</html>