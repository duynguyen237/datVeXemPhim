<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('partials/head') %>
        <title id="movie-title-tab">Chi Tiết Phim - CinéHub</title>
        <style>
            .hero-backdrop {
                background: linear-gradient(135deg, rgba(0, 0, 0, 0.92), rgba(220, 53, 69, 0.4)), url('/images/cinema-bg.jpg');
                background-size: cover;
                background-position: center;
                padding: 60px 0;
            }

            .movie-poster {
                border: 5px solid rgba(255, 255, 255, 0.1);
                border-radius: 15px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            }

            .detail-box {
                background: #1a1a1a;
                border: 1px solid #333;
                border-radius: 15px;
                padding: 25px;
                margin-bottom: 20px;
            }

            /* --- ĐỒNG BỘ GIAO DIỆN ĐẶT VÉ --- */
            #booking-area {
                background: rgba(20, 20, 20, 0.85);
                border: 1px solid #444;
                backdrop-filter: blur(10px);
            }

            .custom-select {
                background-color: #222 !important;
                color: #ffffff !important;
                border: 1px solid #555 !important;
                border-radius: 8px !important;
                padding: 12px 15px !important;
                font-weight: bold;
                transition: 0.3s;
            }

            .custom-select:focus {
                border-color: #ff4d4d !important;
                box-shadow: 0 0 0 0.25rem rgba(255, 77, 77, 0.25) !important;
            }

            /* Định dạng Nút Suất Chiếu */
            .btn-time {
                background: #2a2a2a !important;
                border: 1px solid #444 !important;
                min-width: 140px;
                padding: 15px !important;
                border-radius: 12px;
                transition: 0.3s;
                cursor: pointer;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-decoration: none;
            }

            .btn-time:hover {
                border-color: #ff4d4d !important;
                background: #333 !important;
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(255, 77, 77, 0.2);
            }

            /* Chữ Giờ Chiếu */
            .time-text {
                color: #ff4d4d !important;
                /* Đỏ sáng rực rỡ */
                font-size: 1.6rem;
                font-weight: 800;
                line-height: 1.2;
            }

            /* Chữ Phòng Chiếu */
            .room-text {
                color: #ffffff !important;
                /* Trắng tinh khiết */
                font-size: 15px;
                font-weight: bold;
                margin-top: 5px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .date-header {
                color: #ffc107;
                font-size: 0.9rem;
                font-weight: bold;
                margin-top: 25px;
                border-left: 4px solid #ff4d4d;
                padding-left: 12px;
                letter-spacing: 1px;
            }

            .info-label {
                color: #aaa;
                width: 130px;
                display: inline-block;
                font-size: 0.9rem;
            }
        </style>
</head>

<body class="bg-dark text-white">
    <%- include('partials/header') %>

        <div class="hero-backdrop mb-4">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 text-center mb-4 mb-md-0">
                        <img id="movie-poster" src="" class="movie-poster img-fluid">
                    </div>

                    <div class="col-md-8">
                        <h1 id="movie-name" class="display-5 fw-bold mb-2 text-danger text-uppercase"></h1>
                        <div class="mb-3">
                            <span class="badge bg-danger me-2">T13</span>
                            <span id="movie-duration-badge" class="badge bg-secondary me-2">-- phút</span>
                            <span id="movie-genre" class="badge bg-warning text-dark"></span>
                        </div>
                        <p id="movie-description" class="text-light opacity-75 mb-4"
                            style="text-align: justify; max-height: 100px; overflow-y: auto;"></p>

                        <div id="booking-area" class="p-4 rounded-4 shadow-lg">
                            <h6 class="text-warning fw-bold mb-3 small text-uppercase"><i
                                    class="bi bi-ticket-perforated me-2"></i>Lịch chiếu</h6>

                            <div class="row g-2 mb-3">
                                <div class="col-md-8">
                                    <select id="select-cinema" class="form-select custom-select">
                                        <option value="">-- Chọn rạp chiếu --</option>
                                    </select>
                                </div>
                            </div>

                            <div id="showtime-container" style="display: none;">
                                <div id="showtime-by-date"></div>
                            </div>

                            <div id="no-showtime" class=" py-4" style="display:none;">
                                <label class="text-white small mb-2 fw-bold">Chưa có lịch chiếu</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container pb-5">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="detail-box shadow-sm">
                        <h5 class="text-white mb-4 fw-bold border-bottom pb-2">📋 CHI TIẾT NỘI DUNG</h5>
                        <div class="mb-2"><span class="info-label">Đạo diễn:</span> <span id="director"
                                class="fw-bold text-white"></span></div>
                        <div class="mb-2"><span class="info-label">Diễn viên:</span> <span id="actors"
                                class="fw-bold text-white"></span></div>
                        <div class="mb-2"><span class="info-label">Khởi chiếu:</span> <span id="release-date"
                                class="fw-bold text-info"></span></div>
                        <div class="mb-2"><span class="info-label">Thời lượng:</span> <span id="duration"
                                class="fw-bold text-white"></span></div>
                    </div>

                    <div id="trailer-section" class="detail-box shadow-sm">
                        <h5 class="text-danger mb-4 fw-bold"><i class="bi bi-play-btn-fill me-2"></i>TRAILER PHIM</h5>
                        <div class="ratio ratio-16x9">
                            <iframe id="movie-trailer" class="rounded shadow" src="" allowfullscreen></iframe>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="detail-box text-center shadow-sm">
                        <h5 class="text-warning mb-3 fw-bold">⭐ ĐÁNH GIÁ</h5>
                        <div class="display-4 fw-bold text-warning" id="rating-score">8.6</div>
                        <div class="text-muted small">Dựa trên 18,4k lượt xem</div>
                        <hr class="border-secondary opacity-25">
                        <p class="small text-white-50 italic">Chúc bạn có những giây phút thư giãn tuyệt vời!</p>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script>
                let currentMovieId = null;
                let movieShowtimes = [];

                document.addEventListener('DOMContentLoaded', async () => {
                    const urlParams = new URLSearchParams(window.location.search);
                    currentMovieId = urlParams.get('id');
                    if (currentMovieId) loadMovieDetail(currentMovieId);
                });

                async function loadMovieDetail(id) {
                    try {
                        const res = await fetch(`/api/phim/detail/${id}`);
                        const movie = await res.json();
                        if (!movie) return;

                        document.title = movie.TEN_PHIM + " - CinéHub";
                        document.getElementById('movie-name').textContent = movie.TEN_PHIM;
                        document.getElementById('movie-poster').src = movie.HINH_ANH_POSTER;
                        document.getElementById('movie-description').textContent = movie.NOI_DUNG_PHIM || movie.MO_TA || "Nội dung đang cập nhật...";
                        document.getElementById('movie-genre').textContent = movie.TEN_THE_LOAI || 'Phim';

                        const time = movie.THOI_LUONG_PHIM || movie.THOI_LUONG || 0;
                        document.getElementById('duration').textContent = time + " phút";
                        document.getElementById('movie-duration-badge').textContent = time + " phút";

                        const date = movie.NGAY_KHOI_CHIEU || movie.NGAY_PHAT_HANH;
                        document.getElementById('release-date').textContent = date ? new Date(date).toLocaleDateString('vi-VN') : 'Đang cập nhật';
                        document.getElementById('director').textContent = movie.DAO_DIEN || 'Đang cập nhật';
                        document.getElementById('actors').textContent = movie.DIEN_VIEN || 'Đang cập nhật';

                        const trailerUrl = movie.DUONG_DAN_TRAILER || movie.TRAILER_URL;
                        if (trailerUrl) {
                            const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
                            const match = trailerUrl.match(regExp);
                            if (match) document.getElementById('movie-trailer').src = `https://www.youtube.com/embed/${match[2]}`;
                        }

                        loadShowtimes(id);
                    } catch (e) { console.error("Lỗi:", e); }
                }

                async function loadShowtimes(id) {
                    try {
                        const res = await fetch(`/api/suat-chieu/${id}`);
                        const result = await res.json();
                        if (result.success && result.data.length > 0) {
                            movieShowtimes = result.data;
                            const select = document.getElementById('select-cinema');
                            const cinemas = [...new Set(movieShowtimes.map(s => s.TEN_RAP))];
                            cinemas.forEach(c => {
                                const opt = document.createElement('option');
                                opt.value = c; opt.textContent = c;
                                select.appendChild(opt);
                            });
                        } else {
                            document.getElementById('no-showtime').style.display = 'block';
                        }
                    } catch (e) { console.error("Lỗi:", e); }
                }

                document.getElementById('select-cinema').addEventListener('change', function () {
                    const cinema = this.value;
                    const container = document.getElementById('showtime-container');
                    const listArea = document.getElementById('showtime-by-date');
                    const noShowtime = document.getElementById('no-showtime');

                    listArea.innerHTML = '';
                    noShowtime.style.display = 'none';
                    container.style.display = 'none';

                    if (!cinema) return;

                    const filtered = movieShowtimes.filter(s => s.TEN_RAP === cinema);
                    if (filtered.length === 0) {
                        noShowtime.style.display = 'block';
                        return;
                    }

                    container.style.display = 'block';

                    // Nhóm theo NGAY_FORMAT từ SQL (Chống lỗi 1970)
                    const groupedByDate = filtered.reduce((groups, sc) => {
                        const date = sc.NGAY_FORMAT || sc.NGAY_CHIEU_FORMAT || "Hiện tại";
                        if (!groups[date]) groups[date] = [];
                        groups[date].push(sc);
                        return groups;
                    }, {});

                    for (const date in groupedByDate) {
                        const dateGroup = document.createElement('div');
                        dateGroup.className = 'mb-4';
                        dateGroup.innerHTML = `
                    <div class="date-header mb-3 text-uppercase">Ngày ${date}</div>
                    <div class="d-flex flex-wrap gap-3">
                        ${groupedByDate[date].map(s => {
                            // Lấy Giờ từ SQL (Fix 1970)
                            const displayTime = s.GIO_FORMAT || (s.GIO_BAT_DAU ? s.GIO_BAT_DAU.substring(0, 5) : "--:--");
                            return `
                                <div class="btn btn-time shadow-sm" onclick="window.location.href='/sodoghe?maSuatChieu=${s.MA_SUAT_CHIEU}'">
                                    <div class="time-text">${displayTime}</div>
                                    <div class="room-text">${s.TEN_PHONG_CHIEU}</div>
                                </div>
                            `;
                        }).join('')}
                    </div>
                `;
                        listArea.appendChild(dateGroup);
                    }
                });
            </script>
</body>

</html>