<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('partials/head') %>
        <title id="movie-title-tab">Chi Tiết Phim - CinéHub</title>
        <link rel="stylesheet" href="/css/chitietphim.css">
</head>

<body class="bg-dark text-white">
    <%- include('partials/header') %>

        <div class="hero-backdrop mb-4">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 text-center mb-4 mb-md-0">
                        <img id="movie-poster" src="" class="movie-poster img-fluid">
                    </div>

                    <div class="col-md-8">
                        <h1 id="movie-name" class="display-5 fw-bold mb-2 text-danger text-uppercase"></h1>
                        <div class="mb-3">
                            <span class="badge bg-danger me-2">T13</span>
                            <span id="movie-duration-badge" class="badge bg-secondary me-2">-- phút</span>
                            <span id="movie-genre" class="badge bg-warning text-dark"></span>
                        </div>
                        <p id="movie-description" class="text-light opacity-75 mb-4"
                            style="text-align: justify; max-height: 100px; overflow-y: auto;"></p>

                        <div id="booking-area" class="p-4 rounded-4 shadow-lg mt-4">
                            <h6 class="text-dark fw-bold mb-3 text-uppercase">
                                <i class="bi bi-calendar-check text-danger me-2"></i>Chọn ngày chiếu
                            </h6>

                            <div id="date-selector" class="date-tabs-container mb-4">
                            </div>

                            <h6 class="text-dark fw-bold mb-3 text-uppercase">
                                <i class="bi bi-shop text-danger me-2"></i>Danh sách rạp
                            </h6>

                            <div id="cinema-list-container">
                                <div class="text-center py-4">
                                    <div class="spinner-border text-danger" role="status"></div>
                                    <p class="mt-2 text-dark-50 small">Đang tải lịch chiếu...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container pb-5">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="detail-box shadow-sm">
                        <h5 class="text-dark mb-4 fw-bold border-bottom pb-2">📋 CHI TIẾT NỘI DUNG</h5>
                        <div class="mb-2"><span class="info-label">Đạo diễn:</span> <span id="director"
                                class="fw-bold text-dark"></span></div>
                        <div class="mb-2"><span class="info-label">Diễn viên:</span> <span id="actors"
                                class="fw-bold text-dark"></span></div>
                        <div class="mb-2"><span class="info-label">Khởi chiếu:</span> <span id="release-date"
                                class="fw-bold text-info"></span></div>
                        <div class="mb-2"><span class="info-label">Thời lượng:</span> <span id="duration"
                                class="fw-bold text-dark"></span></div>
                    </div>

                    <div id="trailer-section" class="detail-box shadow-sm">
                        <h5 class="text-danger mb-4 fw-bold"><i class="bi bi-play-btn-fill me-2"></i>TRAILER PHIM</h5>
                        <div class="ratio ratio-16x9">
                            <iframe id="movie-trailer" class="rounded shadow" src="" allowfullscreen></iframe>
                        </div>
                    </div>
                </div>

                <div class="detail-box shadow-sm mt-4">
                    <h5 class="text-warning mb-4 fw-bold border-bottom pb-2"><i class="bi bi-chat-text me-2"></i>BÌNH
                        LUẬN & ĐÁNH GIÁ</h5>

                    <% if (user) { %>
                        <div class="bg-dark p-3 rounded-3 border border-secondary mb-4">
                            <h6 class="text-dark mb-3">Gửi đánh giá của bạn</h6>
                            <form id="formReview" onsubmit="submitReview(event)">
                                <input type="hidden" id="review-maPhim" value="">

                                <div class="mb-3">
                                    <label class="text-dark-50 small mb-2">Chất lượng phim (1-5 sao):</label>
                                    <div class="star-rating">
                                        <input type="radio" id="star5" name="rating" value="5" required /><label
                                            for="star5" title="5 sao"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" id="star4" name="rating" value="4" /><label for="star4"
                                            title="4 sao"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" id="star3" name="rating" value="3" /><label for="star3"
                                            title="3 sao"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" id="star2" name="rating" value="2" /><label for="star2"
                                            title="2 sao"><i class="bi bi-star-fill"></i></label>
                                        <input type="radio" id="star1" name="rating" value="1" /><label for="star1"
                                            title="1 sao"><i class="bi bi-star-fill"></i></label>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <textarea id="review-content"
                                        class="form-control bg-dark text-white border-secondary" rows="3"
                                        placeholder="Chia sẻ cảm nhận của bạn về bộ phim này..." required
                                        maxlength="500"></textarea>
                                </div>
                                <button type="submit" class="btn btn-warning fw-bold px-4 rounded-pill">Gửi Đánh
                                    Giá</button>
                            </form>
                        </div>
                        <% } else { %>
                            <div class="alert alert-secondary bg-dark border-secondary text-white text-center py-3">
                                Vui lòng <a href="/login" class="text-warning fw-bold text-decoration-none">Đăng
                                    nhập</a> để để lại đánh giá của bạn.
                            </div>
                            <% } %>

                                <div id="comments-list">
                                </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script>
                let currentMovieId = null;
                let movieShowtimes = [];
                let datesArray = [];

                document.addEventListener('DOMContentLoaded', async () => {
                    const urlParams = new URLSearchParams(window.location.search);
                    currentMovieId = urlParams.get('id');

                    // Tạo mảng 7 ngày tính từ hôm nay
                    generateSevenDays();

                    if (currentMovieId) await loadMovieDetail(currentMovieId);
                });

                // HÀM 1: TẠO 7 NGÀY
                function generateSevenDays() {
                    const today = new Date();
                    const dayNames = ['CN', 'Th 2', 'Th 3', 'Th 4', 'Th 5', 'Th 6', 'Th 7'];
                    const selector = document.getElementById('date-selector');
                    selector.innerHTML = '';

                    for (let i = 0; i < 7; i++) {
                        let d = new Date(today);
                        d.setDate(d.getDate() + i);

                        // Format ngày chuẩn DD/MM/YYYY để so sánh với Database SQL
                        const dd = String(d.getDate()).padStart(2, '0');
                        const mm = String(d.getMonth() + 1).padStart(2, '0');
                        const yyyy = d.getFullYear();
                        const dateString = `${dd}/${mm}/${yyyy}`;

                        const dayName = (i === 0) ? 'Hôm nay' : dayNames[d.getDay()];
                        const dateDisplay = `${dd}/${mm}`;

                        // Tạo nút HTML
                        const btn = document.createElement('div');
                        btn.className = `date-tab ${i === 0 ? 'active' : ''}`;
                        btn.innerHTML = `
                            <div class="day-name">${dayName}</div>
                            <div class="date-number">${dateDisplay}</div>
                        `;

                        // Sự kiện khi bấm vào 1 ngày
                        btn.onclick = function () {
                            document.querySelectorAll('.date-tab').forEach(el => el.classList.remove('active'));
                            this.classList.add('active');
                            renderShowtimes(dateString); // Đổ lại suất chiếu theo ngày
                        };

                        selector.appendChild(btn);
                        datesArray.push(dateString);
                    }
                }

                async function loadMovieDetail(id) {
                    try {
                        const res = await fetch(`/api/phim/detail/${id}`);
                        const movie = await res.json();
                        if (!movie) return;

                        document.title = movie.TEN_PHIM + " - CinéHub";
                        document.getElementById('movie-name').textContent = movie.TEN_PHIM;
                        document.getElementById('movie-poster').src = movie.HINH_ANH_POSTER;
                        document.getElementById('movie-description').textContent = movie.NOI_DUNG_PHIM || movie.MO_TA || "Nội dung đang cập nhật...";
                        document.getElementById('movie-genre').textContent = movie.TEN_THE_LOAI || 'Phim';

                        const time = movie.THOI_LUONG_PHIM || movie.THOI_LUONG || 0;
                        document.getElementById('duration').textContent = time + " phút";
                        document.getElementById('movie-duration-badge').textContent = time + " phút";

                        const date = movie.NGAY_KHOI_CHIEU || movie.NGAY_PHAT_HANH;
                        document.getElementById('release-date').textContent = date ? new Date(date).toLocaleDateString('vi-VN') : 'Đang cập nhật';
                        document.getElementById('director').textContent = movie.DAO_DIEN || 'Đang cập nhật';
                        document.getElementById('actors').textContent = movie.DIEN_VIEN || 'Đang cập nhật';

                        const trailerUrl = movie.DUONG_DAN_TRAILER || movie.TRAILER_URL;
                        if (trailerUrl) {
                            const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
                            const match = trailerUrl.match(regExp);
                            if (match) document.getElementById('movie-trailer').src = `https://www.youtube.com/embed/${match[2]}`;
                        }

                        // Gọi tiếp hàm lấy suất chiếu sau khi có phim
                        await loadShowtimes(id);
                    } catch (e) { console.error("Lỗi tải phim:", e); }
                }

                // --- HÀM 3: LẤY TẤT CẢ SUẤT CHIẾU VỀ ---
                async function loadShowtimes(id) {
                    try {
                        const res = await fetch(`/api/suat-chieu/${id}`);
                        const result = await res.json();

                        if (result.success && result.data.length > 0) {
                            movieShowtimes = result.data;
                        } else {
                            movieShowtimes = [];
                        }

                        // Đổ dữ liệu ra màn hình cho ngày hôm nay (datesArray[0])
                        renderShowtimes(datesArray[0]);

                    } catch (e) {
                        console.error("Lỗi lấy lịch chiếu:", e);
                        document.getElementById('cinema-list-container').innerHTML = '<p class="text-danger text-center mt-3">Lỗi tải dữ liệu lịch chiếu.</p>';
                    }
                }

                // --- HÀM 4: HIỂN THỊ RẠP VÀ GIỜ RA MÀN HÌNH ---
                function renderShowtimes(selectedDateStr) {
                    const container = document.getElementById('cinema-list-container');
                    container.innerHTML = '';

                    // Lấy ra danh sách các Rạp chiếu (không trùng lặp)
                    const uniqueCinemas = [...new Set(movieShowtimes.map(s => s.TEN_RAP))];

                    if (uniqueCinemas.length === 0) {
                        container.innerHTML = `
                    <div class="text-center py-5 bg-dark rounded border border-secondary shadow-sm mt-3">
                        <i class="bi bi-calendar-x text-secondary" style="font-size: 3rem;"></i>
                        <h6 class="mt-3 text-dark-50">Phim này hiện chưa có lịch chiếu tại bất kỳ rạp nào.</h6>
                    </div>`;
                        return;
                    }

                    // In từng rạp ra màn hình
                    uniqueCinemas.forEach(cinemaName => {
                        // Tìm các suất chiếu CỦA RẠP NÀY + VÀO NGÀY ĐANG CHỌN
                        const times = movieShowtimes.filter(s =>
                            s.TEN_RAP === cinemaName &&
                            (s.NGAY_FORMAT === selectedDateStr || s.NGAY_CHIEU_FORMAT === selectedDateStr)
                        );

                        let timesHtml = '';
                        if (times.length > 0) {
                            timesHtml = times.map(s => {
                                const displayTime = s.GIO_FORMAT || (s.GIO_BAT_DAU ? s.GIO_BAT_DAU.substring(0, 5) : "--:--");
                                return `
                            <div class="btn btn-time shadow-sm" onclick="window.location.href='/sodoghe?maSuatChieu=${s.MA_SUAT_CHIEU}'">
                                <div class="time-text">${displayTime}</div>
                                <div class="room-text">${s.TEN_PHONG_CHIEU}</div>
                            </div>
                        `;
                            }).join('');
                        } else {
                            // Nếu rạp này không có suất trong ngày đang chọn
                            timesHtml = `<div class="text-dark small fst-italic py-2 w-100"><i class="bi bi-info-circle me-1"></i>Không có suất chiếu vào ngày này.</div>`;
                        }

                        container.innerHTML += `
                    <div class="cinema-block shadow-sm">
                        <div class="cinema-title"><i class="bi bi-camera-reels me-2"></i>${cinemaName}</div>
                        <div class="d-flex flex-wrap gap-3">
                            ${timesHtml}
                        </div>
                    </div>
                `;
                    });
                    async function submitReview(e) {
                        e.preventDefault(); // Chặn việc tự động reload trang của Form

                        // Lấy số sao khách chọn
                        const ratingInput = document.querySelector('input[name="rating"]:checked');
                        if (!ratingInput) {
                            alert("Vui lòng chọn số sao đánh giá!");
                            return;
                        }

                        const rating = ratingInput.value;
                        const noiDung = document.getElementById('review-content').value;
                        const maPhim = currentMovieId; // Biến này tụi mình đã khai báo ở đầu file rồi

                        try {
                            // Gửi data xuống cái API vừa viết ở Bước 1
                            const response = await fetch('/api/phim/danh-gia', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ maPhim, rating, noiDung })
                            });

                            const result = await response.json();

                            if (result.success) {
                                // Nếu dùng SweetAlert2 thì chỗ này bung popup lên sẽ cực kỳ đẹp
                                alert("Cảm ơn bạn! Đánh giá đã được ghi nhận.");

                                // Reset form và reload lại để hiện comment mới
                                document.getElementById('formReview').reset();
                                location.reload();
                            } else {
                                alert("Lỗi: " + result.message);
                            }
                        } catch (error) {
                            console.error("Lỗi:", error);
                            alert("Không thể gửi đánh giá lúc này.");
                        }
                    }
                }
            </script>
</body>

</html>