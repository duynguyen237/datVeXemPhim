<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('partials/head') %>
        <title>Đặt Vé - Duy Movie</title>
        <style>
            .booking-hero {
                background: linear-gradient(135deg, #1a1a1a, #2d1b69);
            }

            .form-control:focus {
                border-color: #dc3545;
                box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, .25);
            }

            /* Hiệu ứng cho nút Giờ Chiếu */
            .showtime-btn {
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                border-width: 2px;
                background-color: #2c2c2c;
                color: #dc3545;
            }

            .showtime-btn:hover {
                transform: translateY(-5px);
                box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4);
                background-color: #3d3d3d;
            }

            /* Hiệu ứng rực rỡ khi nút ĐÃ ĐƯỢC CHỌN */
            .showtime-btn.selected {
                background-color: #dc3545 !important;
                color: white !important;
                transform: scale(1.08);
                box-shadow: 0 8px 25px rgba(220, 53, 69, 0.7);
                border-color: #dc3545;
            }
        </style>
</head>

<body class="bg-dark text-white">
    <%- include('partials/header') %>

        <div class="booking-hero py-5 mb-5">
            <div class="container">
                <h1 class="display-4 fw-bold text-center text-white mb-4">
                    <i class="bi bi-ticket-detailed text-danger"></i> ĐẶT VÉ XEM PHIM
                </h1>
                <p class="lead text-center text-white-50 mb-5">Chọn phim, rạp, giờ chiếu - Đặt vé dễ dàng chỉ trong 3
                    bước!</p>
            </div>
        </div>

        <div class="container mb-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card bg-secondary text-white border-0 shadow-lg">
                        <div class="card-body p-5">
                            <form id="booking-form">
                                <div class="row g-4">
                                    <div class="col-12">
                                        <label class="form-label fw-bold text-white fs-5">🎥 BƯỚC 1: Chọn phim</label>
                                        <select id="movie-select" class="form-select form-select-lg" required>
                                            <option value="">-- Chọn phim --</option>
                                        </select>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-white">📅 Ngày chiếu</label>
                                        <select id="date-select" class="form-select">
                                            <option value="">-- Chọn ngày --</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-white">🏛️ Rạp</label>
                                        <select id="cinema-select" class="form-select">
                                            <option value="">-- Chọn rạp --</option>
                                        </select>
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label fw-bold text-white fs-5">⏰ BƯỚC 2: Chọn giờ
                                            chiếu</label>
                                        <div id="showtime-list" class="row g-3 mt-2">
                                        </div>
                                    </div>

                                    <div class="col-12 text-center">
                                        <button type="submit" class="btn btn-danger btn-lg px-5 py-3 fw-bold shadow-lg"
                                            id="next-step-btn" disabled>
                                            <i class="bi bi-arrow-right-circle me-2"></i>TIẾP TỤC CHỌN GHẾ
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script>
                let selectedShowtime = null;
                let allShowtimes = []; // Biến toàn cục để lưu toàn bộ suất chiếu của phim được chọn

                document.addEventListener('DOMContentLoaded', async () => {
                    await loadMovies();
                    setupEventListeners();
                });

                // 1. Load danh sách phim vào Bước 1
                async function loadMovies() {
                    try {
                        const response = await fetch('/api/phim/all');
                        const result = await response.json();

                        if (result.success) {
                            const movieSelect = document.getElementById('movie-select');
                            result.data.forEach(phim => {
                                movieSelect.innerHTML += `<option value="${phim.MA_PHIM}">${phim.TEN_PHIM}</option>`;
                            });
                        }
                    } catch (error) {
                        console.error('Lỗi load phim:', error);
                    }
                }

                function setupEventListeners() {
                    document.getElementById('movie-select').addEventListener('change', onMovieChange);
                    document.getElementById('date-select').addEventListener('change', onDateChange);
                    document.getElementById('cinema-select').addEventListener('change', onCinemaChange);

                    document.getElementById('booking-form').addEventListener('submit', function (e) {
                        e.preventDefault();
                        if (selectedShowtime) {
                            // SỬA LỖI LINK: Chuyển hướng sang trang Sơ đồ ghế (/sodoghe) kèm ID suất chiếu
                            window.location.href = `/sodoghe?id=${selectedShowtime}`;
                        }
                    });
                }

                // 2. Khi chọn Phim -> Gọi API lấy TẤT CẢ suất chiếu của phim đó
                async function onMovieChange() {
                    const maPhim = document.getElementById('movie-select').value;
                    resetForm();

                    if (!maPhim) return;

                    try {
                        const response = await fetch(`/api/suat-chieu/${maPhim}`);
                        const result = await response.json();

                        if (result.success && result.data.length > 0) {
                            allShowtimes = result.data; // Lưu lại dữ liệu thật từ DB

                            // Lọc ra các ngày chiếu duy nhất (không trùng lặp)
                            const uniqueDates = [...new Set(allShowtimes.map(sc => sc.NGAY_CHIEU.split('T')[0]))];

                            const dateSelect = document.getElementById('date-select');
                            uniqueDates.forEach(date => {
                                const displayDate = new Date(date).toLocaleDateString('vi-VN');
                                dateSelect.innerHTML += `<option value="${date}">${displayDate}</option>`;
                            });
                        } else {
                            alert('Phim này hiện chưa có lịch chiếu!');
                        }
                    } catch (error) {
                        console.error('Lỗi load suất chiếu:', error);
                    }
                }

                // 3. Khi chọn Ngày -> Lọc ra các Rạp có chiếu trong ngày đó
                function onDateChange() {
                    const selectedDate = document.getElementById('date-select').value;
                    const cinemaSelect = document.getElementById('cinema-select');

                    // Reset Rạp và Giờ chiếu
                    cinemaSelect.innerHTML = '<option value="">-- Chọn rạp --</option>';
                    document.getElementById('showtime-list').innerHTML = '';
                    document.getElementById('next-step-btn').disabled = true;

                    if (!selectedDate) return;

                    // Lọc suất chiếu theo ngày -> Lấy tên các rạp không trùng lặp
                    const showtimesOnDate = allShowtimes.filter(sc => sc.NGAY_CHIEU.startsWith(selectedDate));
                    const uniqueCinemas = [...new Set(showtimesOnDate.map(sc => sc.TEN_RAP))];

                    uniqueCinemas.forEach(cinema => {
                        cinemaSelect.innerHTML += `<option value="${cinema}">${cinema}</option>`;
                    });
                }

                // 4. Khi chọn Rạp -> Hiển thị các Giờ chiếu tương ứng
                function onCinemaChange() {
                    const selectedDate = document.getElementById('date-select').value;
                    const selectedCinema = document.getElementById('cinema-select').value;
                    const showtimeList = document.getElementById('showtime-list');

                    showtimeList.innerHTML = '';
                    document.getElementById('next-step-btn').disabled = true;

                    if (!selectedDate || !selectedCinema) return;

                    // Lọc ra các suất chiếu khớp cả Ngày và Rạp
                    const finalShowtimes = allShowtimes.filter(sc =>
                        sc.NGAY_CHIEU.startsWith(selectedDate) && sc.TEN_RAP === selectedCinema
                    );

                    if (finalShowtimes.length === 0) {
                        showtimeList.innerHTML = '<p class="text-warning mt-3">Không có suất chiếu nào phù hợp.</p>';
                        return;
                    }

                    // Render nút Giờ chiếu
                    finalShowtimes.forEach(sc => {
                        // SỬA LỖI 1970: Cắt chuỗi an toàn để lấy giờ:phút
                        let timeString = '00:00';
                        if (sc.GIO_BAT_DAU) {
                            if (sc.GIO_BAT_DAU.includes('T')) {
                                timeString = sc.GIO_BAT_DAU.split('T')[1].substring(0, 5);
                            } else {
                                timeString = sc.GIO_BAT_DAU.substring(0, 5);
                            }
                        }

                        showtimeList.innerHTML += `
            <div class="col-md-3 col-6 mb-3">
                <button type="button" class="btn btn-outline-danger w-100 p-3 showtime-btn" 
                        onclick="selectShowtime(this, ${sc.MA_SUAT_CHIEU})">
                    <strong class="fs-4 d-block mb-1"><i class="bi bi-clock"></i> ${timeString}</strong>
                    <small class="d-block">${sc.TEN_PHONG_CHIEU}</small>
                </button>
            </div>
        `;
                    });
                }

                // 5. Hàm chọn Giờ chiếu (Đã thêm CSS Class selected)
                window.selectShowtime = function (btnElement, maSuat) {
                    selectedShowtime = maSuat;

                    // Xóa class selected ở tất cả các nút
                    document.querySelectorAll('.showtime-btn').forEach(btn => {
                        btn.classList.remove('selected');
                    });

                    // Thêm class selected cho nút vừa click
                    btnElement.classList.add('selected');

                    // Mở khóa nút "Tiếp tục"
                    const nextBtn = document.getElementById('next-step-btn');
                    nextBtn.disabled = false;

                    // Cuộn màn hình xuống nút Tiếp tục
                    nextBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }

                // Hàm dọn dẹp form khi chọn lại Phim từ đầu
                function resetForm() {
                    allShowtimes = [];
                    selectedShowtime = null;
                    document.getElementById('date-select').innerHTML = '<option value="">-- Chọn ngày --</option>';
                    document.getElementById('cinema-select').innerHTML = '<option value="">-- Chọn rạp --</option>';
                    document.getElementById('showtime-list').innerHTML = '';
                    document.getElementById('next-step-btn').disabled = true;
                }
            </script>
</body>

</html>