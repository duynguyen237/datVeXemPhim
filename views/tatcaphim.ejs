<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('partials/head') %>
        <title>Tất cả phim chiếu rạp - MoMo Cinema</title>
        <link rel="stylesheet" href="/css/home.css">
</head>

<body class="bg-white text-dark">
    <%- include('partials/header') %>

        <div class="container py-5 mt-3">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="title-border fw-bold m-0 fs-3" style="color: var(--momo-pink-dark);">Tất cả phim chiếu rạp
                </h2>

                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 small fw-medium">
                        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-secondary">Trang
                                chủ</a></li>
                        <li class="breadcrumb-item active" aria-current="page" style="color: var(--momo-pink);">Tất cả
                            phim</li>
                    </ol>
                </nav>
            </div>

            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-4 mb-5">
                <% if (movies && movies.length> 0) { %>
                    <% movies.forEach(movie=> { %>
                        <div class="col">
                            <div class="movie-card"
                                onclick="window.location.href='/chitietphim?id=<%= movie.MA_PHIM %>'">
                                <div class="movie-poster-wrapper position-relative rounded-3 overflow-hidden shadow-sm">
                                    <span class="badge bg-danger position-absolute top-0 start-0 m-2 z-2">
                                        <%= movie.GIOI_HAN_TUOI %>+
                                    </span>

                                    <img src="<%= movie.HINH_ANH_NEN %>" class="w-100"
                                        style="height: 300px; object-fit: cover;" alt="<%= movie.TEN_PHIM %>">

                                    <div
                                        class="movie-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                                        <i class="bi bi-play-circle text-white shadow-sm"
                                            style="font-size: 3.5rem;"></i>
                                    </div>
                                </div>

                                <div class="movie-info mt-2 text-start">
                                    <h3 class="fs-6 fw-bold text-dark text-truncate mb-1" title="<%= movie.TEN_PHIM %>">
                                        <%= movie.TEN_PHIM %>
                                    </h3>
                                    <p class="text-secondary small mb-1">Thể loại đang cập nhật</p>
                                    <p class="text-warning small mb-0"><i class="bi bi-star-fill"></i> 9.0</p>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="col-12 text-center py-5">
                                    <img src="https://homepage.momocdn.net/fileuploads/svg/momo-file-240411162904.svg"
                                        width="80" class="mb-3 opacity-50" alt="No data">
                                    <p class="text-muted fs-5">Hiện chưa có bộ phim nào trong hệ thống!</p>
                                </div>
                                <% } %>
            </div>
        </div>

        <%- include('partials/footer') %>
</body>

</html>