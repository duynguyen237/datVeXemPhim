<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kết Quả Thanh Toán - CinéHub</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Roboto:wght@400;500&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-color: #ff3333;
            /* Đỏ rạp phim */
            --success-color: #28a745;
            --bg-light: #f4f7f6;
        }

        body {
            background-color: var(--bg-light);
            font-family: 'Roboto', sans-serif;
            color: #333;
        }

        .main-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* Hiệu ứng Ticket */
        .ticket-card {
            background: #fff;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            max-width: 500px;
            width: 100%;
            position: relative;
        }

        .status-header {
            padding: 40px 20px;
            text-align: center;
            color: white;
        }

        .status-header.success {
            background: linear-gradient(135deg, #28a745, #1e7e34);
        }

        .status-header.fail {
            background: linear-gradient(135deg, #dc3545, #a71d2a);
        }

        .status-icon {
            font-size: 4rem;
            margin-bottom: 15px;
            display: block;
        }

        .ticket-body {
            padding: 30px;
            position: relative;
        }

        /* Đường răng cưa vé */
        .ticket-divider {
            position: relative;
            height: 2px;
            border-top: 2px dashed #e0e0e0;
            margin: 20px 0;
        }

        .ticket-divider::before,
        .ticket-divider::after {
            content: "";
            position: absolute;
            top: -10px;
            width: 20px;
            height: 20px;
            background-color: var(--bg-light);
            border-radius: 50%;
        }

        .ticket-divider::before {
            left: -40px;
        }

        .ticket-divider::after {
            right: -40px;
        }

        .info-label {
            color: #888;
            font-size: 0.85rem;
            text-transform: uppercase;
            margin-bottom: 2px;
        }

        .info-value {
            font-weight: 500;
            font-size: 1.05rem;
            margin-bottom: 15px;
        }

        .movie-title {
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            color: var(--primary-color);
            font-size: 1.4rem;
            line-height: 1.2;
        }

        .btn-home {
            background-color: #333;
            color: white;
            border: none;
            padding: 12px;
            font-weight: 600;
            transition: 0.3s;
        }

        .btn-home:hover {
            background-color: #000;
            color: white;
        }

        .btn-history {
            border: 2px solid #333;
            color: #333;
            font-weight: 600;
        }

        .qr-placeholder {
            border: 1px solid #eee;
            padding: 10px;
            border-radius: 10px;
            display: inline-block;
        }
    </style>
</head>

<body>

    <div class="main-container">
        <div class="ticket-card animate__animated animate__fadeInUp">

            <% if (success) { %>
                <div class="status-header success">
                    <i class="bi bi-check-circle-fill status-icon"></i>
                    <h3 class="fw-bold mb-0">THANH TOÁN THÀNH CÔNG</h3>
                </div>
                <% } else { %>
                    <div class="status-header fail">
                        <i class="bi bi-x-circle-fill status-icon"></i>
                        <h3 class="fw-bold mb-0">THANH TOÁN THẤT BẠI</h3>
                    </div>
                    <% } %>

                        <div class="ticket-body">
                            <% if (success) { %>
                                <div class="mb-4 text-center text-sm-start">
                                    <div class="info-label">Phim đã đặt</div>
                                    <div class="movie-title text-uppercase">
                                        <%= data[0].TEN_PHIM %>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-6">
                                        <div class="info-label">Ngày chiếu</div>
                                        <div class="info-value">
                                            <%= new Date(data[0].NGAY_CHIEU).toLocaleDateString('vi-VN', {
                                                day: '2-digit' , month: '2-digit' , year: 'numeric' }) %>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="info-label">Suất chiếu (Giờ)</div>
                                        <div class="info-value">
                                            <%= new Date(data[0].GIO_CHIEU).toLocaleTimeString('vi-VN', {
                                                hour: '2-digit' , minute: '2-digit' , hour12: false }) %>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-6">
                                        <div class="info-label">Phòng chiếu</div>
                                        <div class="info-value">Premium Cinema</div>
                                    </div>
                                    <div class="col-6">
                                        <div class="info-label">Ghế ngồi</div>
                                        <div class="info-value text-danger fw-bold">
                                            <%= data[0].DANH_SACH_GHE %>
                                        </div>
                                    </div>
                                </div>

                                <div class="ticket-divider"></div>

                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <div>
                                        <div class="info-label">Tổng cộng</div>
                                        <div class="h4 fw-bold text-success mb-0">
                                            <%= data[0].TONG_TIEN.toLocaleString() %> đ
                                        </div>
                                    </div>
                                    <div class="text-center">
                                        <div class="qr-placeholder">
                                            <i class="bi bi-qr-code" style="font-size: 2.5rem;"></i>
                                        </div>
                                        <div style="font-size: 0.6rem; color: #999;">Mã vào cổng</div>
                                    </div>
                                </div>

                                <% } else { %>
                                    <div class="text-center py-4">
                                        <h5 class="text-muted mb-3">Rất tiếc! Giao dịch của bạn đã gặp sự cố.</h5>
                                        <p
                                            class="text-danger p-3 bg-light rounded border border-danger border-opacity-25">
                                            Lý do: <%= message %>
                                        </p>
                                        <p class="small text-muted mt-4">Vui lònglòng thử lại sau!!</p>
                                    </div>
                                    <% } %>

                                        <div class="d-grid gap-2 mt-2">
                                            <a href="/" class="btn btn-home btn-lg rounded-pill">Quay lại Trang chủ</a>
                                            <% if (success) { %>
                                                <a href="/lich-su" class="btn btn-history btn-lg rounded-pill mt-1">Xem
                                                    lịch sử đặt vé</a>
                                                <% } else { %>
                                                    <a href="javascript:history.back()"
                                                        class="btn btn-outline-dark btn-lg rounded-pill mt-1">Thanh toán
                                                        lại</a>
                                                    <% } %>
                                        </div>

                                        <div class="text-center mt-4">
                                            <small class="text-muted">© 2026 CinéHub Entertainment. All rights
                                                reserved.</small>
                                        </div>
                        </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>