<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('partials/head') %>
        <title>Thanh Toán - CinéHub</title>
        <link rel="stylesheet" href="/css/thanhtoan.css">
</head>

<body class="bg-dark text-white">
    <%- include('partials/header') %>

        <div class="container mt-5 pb-5">
            <h2 class="text-danger fw-bold mb-4 text-center">CHI TIẾT THANH TOÁN</h2>

            <div class="row g-4">
                <div class="col-md-5">
                    <div class="checkout-box shadow">
                        <h5 class="text-warning mb-4"><i class="fas fa-user me-2"></i>Thông tin liên hệ</h5>
                        <div class="mb-3">
                            <label class="small text-secondary">Họ tên *</label>
                            <input type="text" id="cus_name" class="form-control" placeholder="Đang tải...">
                        </div>
                        <div class="mb-3">
                            <label class="small text-secondary">Số điện thoại *</label>
                            <input type="text" id="cus_phone" class="form-control" placeholder="Đang tải...">
                        </div>
                        <div class="mb-3">
                            <label class="small text-secondary">Email</label>
                            <input type="email" id="cus_email" class="form-control" placeholder="Đang tải...">
                        </div>
                    </div>
                </div>

                <div class="col-md-7">
                    <div class="checkout-box shadow">
                        <h5 class="text-warning mb-4"><i class="fas fa-shopping-cart me-2"></i>Đơn hàng của bạn</h5>
                        <table class="table table-borderless">
                            <thead>
                                <tr class="border-bottom border-secondary text-secondary">
                                    <th>Sản phẩm / Ghế</th>
                                    <th class="text-center">SL</th>
                                    <th class="text-end">Giá</th>
                                </tr>
                            </thead>
                            <tbody id="billing-body">
                                <tr>
                                    <td colspan="3" class="text-center text-muted">Đang tải chi tiết đơn hàng...</td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="border-top border-secondary pt-3 mt-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h4 class="mb-0">TỔNG CỘNG</h4>
                                <h3 class="text-danger fw-bold mb-0" id="final-total"></h3>
                            </div>
                        </div>

                        <button class="btn btn-danger w-100 mt-4 py-3 fw-bold rounded-pill" onclick="submitOrder()">
                            XÁC NHẬN & THANH TOÁN
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script src="/js/thanhtoan.js"></script>
</body>

</html>